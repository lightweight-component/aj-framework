<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.ajaxjs</groupId>
        <artifactId>aj-common-parent</artifactId>
        <version>2.4</version>
        <relativePath/>
    </parent>

    <artifactId>aj-base</artifactId>
    <packaging>jar</packaging>
    <version>1.0</version>
    <name>aj-base</name>
    <description>еҹәзЎҖжңҚеҠЎ</description>

    <build>
        <plugins>
            <!-- з”ҹжҲҗ META-INF/MANIFEST.MF ж–Үд»¶зҡ„йғЁеҲҶеҶ…е®№ -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.3.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <addClasspath>true</addClasspath>
                            <classpathPrefix>lib/</classpathPrefix>
                            <!-- иҝҷйҮҢжҳҜйЎ№зӣ®дё»зұ»иҝҗиЎҢе…ҘеҸЈ -->
                            <mainClass>com.ajaxjs.base.BaseApplication</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <!--дёҖй”®йғЁзҪІеҲ°жңҚеҠЎеҷЁ SSH-->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>wagon-maven-plugin</artifactId>
                <version>2.0.2</version>

                <executions>
                    <execution>
                        <id>upload-deploy</id>
                        <!-- иҝҗиЎҢpackageжү“еҢ…зҡ„еҗҢж—¶иҝҗиЎҢupload-singleе’Ңsshexec -->
                        <phase>package</phase>
                        <goals>
                            <goal>upload-single</goal>
                            <goal>sshexec</goal>
                        </goals>
                        <configuration>
                            <!-- жҢҮе®ҡ SSH иҙҰеҸ· -->
                            <serverId>usa.ajaxjs.com</serverId>
                            <!-- иҰҒжӣҙж–°зҡ„ jar еҢ… -->
                            <fromFile>target/aj-base.jar</fromFile>
                            <!-- жңҚеҠЎеҷЁйғЁзҪІдҪҚзҪ® -->
                            <url>${ssh.url.base}</url>
                            <!-- йҮҚеҗҜи„ҡжң¬ е…ҲеҲҮжҚўзӣ®еҪ•пјҢжүҚиғҪжӯЈзЎ®жү§иЎҢи„ҡжң¬ -->
                            <commands>
                                <command>cd /home/service/aj-base;./startup.sh</command>
                            </commands>
                            <!-- жҳҫзӨәиҝҗиЎҢе‘Ҫд»Өзҡ„иҫ“еҮәз»“жһң -->
                            <displayCommandOutputs>true</displayCommandOutputs>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <!-- и®ӨиҜҒ SDK -->
<!--        <dependency>
            <groupId>com.ajaxjs</groupId>
            <artifactId>aj-iam-client</artifactId>
            <version>1.1</version>
        </dependency>-->
        <dependency>
            <groupId>com.ajaxjs</groupId>
            <artifactId>aj-framework-common</artifactId>
            <version>1.0</version>
        </dependency>

        <dependency>
            <groupId>org.wltea</groupId>  
            <artifactId>IKAnalyzer2012</artifactId>    
            <version>1.0</version> 
            <scope>system</scope> <!--systemпјҢзұ»дјјprovidedпјҢйңҖиҰҒжҳҫејҸжҸҗдҫӣдҫқиө–зҡ„jarд»ҘеҗҺпјҢMavenе°ұдёҚдјҡеңЁRepositoryдёӯжҹҘжүҫе®ғ-->
            <systemPath>${basedir}/jar/IKAnalyzer2012.jar</systemPath> <!--йЎ№зӣ®ж №зӣ®еҪ•дёӢзҡ„libж–Үд»¶еӨ№дёӢпјҢд№ҹеҸҜд»ҘжҳҜжң¬жңәе…¶е®ғзӣ®еҪ•зҡ„з»қеҜ№и·Ҝеҫ„-->
        </dependency>

        <dependency>
            <groupId>org.wltea</groupId>  
            <artifactId>lucene</artifactId>    
            <version>1.0</version> 
            <scope>system</scope> <!--systemпјҢзұ»дјјprovidedпјҢйңҖиҰҒжҳҫејҸжҸҗдҫӣдҫқиө–зҡ„jarд»ҘеҗҺпјҢMavenе°ұдёҚдјҡеңЁRepositoryдёӯжҹҘжүҫе®ғ-->
            <systemPath>${basedir}/jar/lucene-core-3.6.0.jar</systemPath> <!--йЎ№зӣ®ж №зӣ®еҪ•дёӢзҡ„libж–Үд»¶еӨ№дёӢпјҢд№ҹеҸҜд»ҘжҳҜжң¬жңәе…¶е®ғзӣ®еҪ•зҡ„з»қеҜ№и·Ҝеҫ„-->
        </dependency>
    </dependencies>
</project>